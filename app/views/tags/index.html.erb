<%= render "shared/page_card",
      title: "タグ一覧",
      icon: "fa-solid fa-tags" do %>

  <% if @tags.present? %>
    <div class="list-group list-group-flush">
      <% @tags.each do |tag| %>
        <%= link_to tag_path(tag),
              class: "list-group-item list-group-item-action border-0 rounded-3 mb-2 tag-list-item" do %>

          <div class="d-flex justify-content-between align-items-center">
            <span class="tag-badge">
              #<%= tag.name %>
            </span>

            <span class="text-muted">
              <%= tag.posts.count %>件
            </span>
          </div>

        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-muted mb-0">
      タグはまだありません。
    </p>
  <% end %>

<% end %>
<div class="container py-4">
  <h2 class="fw-bold mb-4 text-center">
    <i class="fa-solid fa-tags"></i>
    #<%= @tag.name %> の投稿一覧
  </h2>

  <% if @posts.present? %>
    <div class="row">
      <%= render partial: "posts/post",
            collection: @posts %>
    </div>
  <% else %>
    <div class="text-center text-muted py-5">
      このタグが付いた投稿はまだありません。
    </div>
  <% end %>
</div>
<div class="container py-4">
  <h2 class="fw-bold mb-4 text-center">
    <i class="fa-solid fa-tags"></i>
    #<%= @tag.name %> の投稿一覧
  </h2>

  <% if @posts.present? %>
    <div class="row">
      <% @posts.each do |post| %>
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card shadow-sm border-0 rounded-4 h-100">

            <% if post.images.attached? %>
              <%= image_tag post.images.first,
                    class: "card-img-top",
                    style: "height: 220px; object-fit: contain;" %>
            <% else %>
              <div class="bg-light d-flex justify-content-center align-items-center text-muted"
                   style="height: 220px;">
                No Image
              </div>
            <% end %>

            <div class="card-body d-flex flex-column">

              <h5 class="fw-bold mb-2">
                <i class="fa-solid fa-location-dot text-danger"></i>
                <%= post.place_name %>
              </h5>

              <p class="mb-2">
                <strong><%= post.title %></strong>
              </p>

              <div class="text-warning mb-2">
                <div class="raty-read-only" data-score="<%= post.rating %>"></div>
              </div>

              <% if post.tags.present? %>
                <div class="d-flex flex-wrap gap-2 mb-3">
                  <% post.tags.each do |tag| %>
                    <%= link_to "##{tag.name}",
                          tag_path(tag),
                          class: "tag-badge" %>
                  <% end %>
                </div>
              <% end %>

              <p class="text-muted small mb-3">
                投稿者：<%= post.user.name %>
              </p>

              <div class="mt-auto">

                <div class="d-flex gap-2 align-items-center mb-3">

                  <% if logged_in? %>

                    <% if post.favorited_by?(current_user) %>

                      <%= link_to post_favorite_path(post),
                            data: { turbo_method: :delete },
                            class: "btn btn-outline-danger rounded-pill btn-sm" do %>
                        <i class="fa-solid fa-heart"></i>
                        <%= post.favorites.count %>
                      <% end %>

                    <% else %>

                      <%= link_to post_favorite_path(post),
                            data: { turbo_method: :post },
                            class: "btn btn-outline-secondary rounded-pill btn-sm" do %>
                        <i class="fa-regular fa-heart"></i>
                        <%= post.favorites.count %>
                      <% end %>

                    <% end %>

                  <% else %>

                    <span class="btn btn-outline-secondary rounded-pill btn-sm disabled">
                      <i class="fa-regular fa-heart"></i>
                      <%= post.favorites.count %>
                    </span>

                  <% end %>

                  <%= link_to post_path(post),
                        class: "btn btn-outline-secondary rounded-pill btn-sm" do %>
                    <i class="fa-regular fa-comment-dots"></i>
                    <%= post.comments.count %>
                  <% end %>

                </div>

                <%= link_to "詳細を見る",
                      post_path(post),
                      data: { turbo: false },
                      class: "btn btn-asobow w-100 rounded-pill" %>

              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

  <% else %>

    <div class="text-center text-muted py-5">
      このタグが付いた投稿はまだありません
    </div>

  <% end %>
</div>
<div class="container my-4">
  <h2 class="text-center mb-3">検索結果</h2>

  <p class="text-center mb-4">
    「<%= @word %>」の検索結果
  </p>

  <% if @range == "User" %>
    <h3 class="mb-3">ユーザー</h3>

    <% if @users.present? %>
      <% @users.each do |user| %>
        <div class="card mb-3 shadow-sm border-0 rounded-4">
          <div class="card-body">
            <h5 class="card-title">
              <i class="fa-solid fa-user"></i>
              <%= link_to user.name, user_path(user), class: "text-decoration-none text-dark" %>
            </h5>
          </div>
        </div>
      <% end %>
      <div class="d-flex justify-content-center mt-4">
        <%= paginate @users %>
      </div>
    <% else %>
      <p class="text-center text-muted mb-0">該当するユーザーはいません。</p>
    <% end %>

  <% elsif @range == "Post" %>
    <h3 class="mb-3">投稿</h3>

    <% if @posts.present? %>
      <% @posts.each do |post| %>
        <div class="card mb-3 shadow-sm border-0 rounded-4">
          <div class="card-body">
            <h5 class="card-title">
              <i class="fa-solid fa-paw"></i>
              <%= link_to post.place_name, post_path(post), class: "text-decoration-none text-dark" %>
            </h5>

            <p class="card-text mb-1">
              <i class="fa-solid fa-location-dot"></i>
              <%= post.address %>
            </p>
          </div>
        </div>
      <% end %>
      <div class="d-flex justify-content-center mt-4">
        <%= paginate @posts %>
      </div>
    <% else %>
      <p class="text-center text-muted mb-0">該当する投稿はありません。</p>
    <% end %>

  <% elsif @range == "Tag" %>
    <h3 class="mb-3">タグ</h3>

    <% if @tags.present? %>
      <% @tags.each do |tag| %>
        <div class="card mb-3 shadow-sm border-0 rounded-4">
          <div class="card-body">
            <h5 class="card-title mb-0">
              <i class="fa-solid fa-tags"></i>
              <%= link_to "##{tag.name}",
                    tag_path(tag),
                    class: "text-decoration-none text-dark" %>
            </h5>
          </div>
        </div>
      <% end %>
      <div class="d-flex justify-content-center mt-4">
        <%= paginate @tags %>
      </div>
    <% else %>
      <p class="text-center text-muted mb-0">該当するタグはありません。</p>
    <% end %>

  <% elsif @range == "Community" %>
    <h3 class="mb-3">コミュニティ</h3>

    <% if @communities.present? %>
      <% @communities.each do |community| %>
        <div class="card mb-3 shadow-sm border-0 rounded-4">
          <div class="card-body">
            <h5 class="card-title mb-0">
              <i class="fa-solid fa-people-group"></i>
              <%= link_to community.name, community_path(community), class: "text-decoration-none text-dark" %>
            </h5>
          </div>
        </div>
      <% end %>
      <div class="d-flex justify-content-center mt-4">
        <%= paginate @communities %>
      </div>
    <% else %>
      <p class="text-center text-muted mb-0">該当するコミュニティはありません。</p>
    <% end %>
  <% end %>
</div>

<h2>投稿一覧</h2>

<table>
  <thead>
    <tr>
      <th>タイトル</th>
      <th>評価</th>
      <th>場所名</th>
      <th>投稿者</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @posts.each do |post| %>
      <tr>
        <td><%= post.title %></td>
        <td><%= post.rating %></td>
        <td><%= post.place_name %></td>
        <td><%= post.user.name %></td>
        <td><%= link_to "詳細", post_path(post), data: { turbo: false } %></td>
      </tr>
    <% end %>
  </tbody>
</table>


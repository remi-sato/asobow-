<div class="container py-4">
  <h2 class="fw-bold mb-4 text-center">
    <i class="fa-solid fa-tree"></i>
    投稿一覧
  </h2>

  <div class="row">
    <% @posts.each do |post| %>
      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card shadow-sm border-0 rounded-4 h-100">

          <% if post.images.attached? %>
            <%= image_tag post.images.first,
                class: "card-img-top",
                style: "height:220px; object-fit:contain;" %>
          <% else %>
            <div class="bg-light d-flex justify-content-center align-items-center text-muted" style="height: 220px;">
              No Image
            </div>
          <% end %>

          <div class="card-body d-flex flex-column">

            <h5 class="fw-bold mb-2">
              <i class="fa-solid fa-location-dot text-danger"></i>
              <%= post.place_name %>
            </h5>

            <p class="mb-2">
              <strong><%= post.title %></strong>
            </p>

            <p class="text-warning mb-2">
              ★ <%= post.rating %> / 5
            </p>

            <p class="text-muted small">
              投稿者：<%= post.user.name %>
            </p>

            <div class="mt-auto">
              <%= link_to "詳細を見る", post_path(post), data: { turbo: false }, class: "btn btn-asobow w-100 rounded-pill" %>
            </div>

          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
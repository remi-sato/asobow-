<div class="container py-4">
  <h2 class="fw-bold mb-4 text-center">
    <i class="fa-solid fa-tree"></i>
    投稿一覧
  </h2>

  <div class="row">
    <% @posts.each do |post| %>
      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card shadow-sm border-0 rounded-4 h-100">

          <% if post.images.attached? %>
            <%= image_tag post.images.first,
                class: "card-img-top",
                style: "height: 220px; object-fit: contain;" %>
          <% else %>
            <div class="bg-light d-flex justify-content-center align-items-center text-muted"
                 style="height: 220px;">
              No Image
            </div>
          <% end %>

          <div class="card-body d-flex flex-column">
            <h5 class="card-title fw-bold">
              <%= post.place_name %>
            </h5>

            <p class="text-muted mb-2">
              <i class="fa-solid fa-location-dot text-danger"></i>
              <%= post.address %>
            </p>

            <p class="card-text text-truncate">
              <%= post.body %>
            </p>

            <div class="mt-auto">

              <div class="d-flex justify-content-between align-items-center mb-2">
                <small class="text-muted">
                  投稿者：
                  <%= link_to post.user.name, user_path(post.user), class: "text-decoration-none" %>
                </small>

                <small class="text-muted">
                  <%= post.created_at.strftime("%Y/%m/%d") %>
                </small>
              </div>

              <div class="d-flex justify-content-between align-items-center">

                <div>
                  <i class="fa-solid fa-heart text-danger"></i>
                  <%= post.favorites.count %>

                  <span class="ms-3">
                    <i class="fa-solid fa-comment text-primary"></i>
                    <%= post.comments.count %>
                  </span>
                </div>

                <%= link_to "詳細を見る",
                    post_path(post),
                    class: "btn btn-outline-primary rounded-pill" %>

              </div>

            </div>
          </div>

        </div>
      </div>
    <% end %>
  </div>
</div>
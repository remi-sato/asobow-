<div class="container py-4">
  <div class="text-center mb-4">
    <h2 class="fw-bold mb-4 text-center">
      <i class="fa-solid fa-tree"></i>
      投稿一覧
    </h2>

    <% if logged_in? %>
        <%= link_to new_post_path,
              data: { turbo: false },
              class: "btn btn-asobow rounded-pill px-4 fw-bold" do %>
          <i class="fa-solid fa-paw"></i>
         遊び場を投稿する
        <% end %>
    <% end %>
  </div>

  <div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-body p-4">
      <h5 class="fw-bold mb-4">
        <i class="fa-solid fa-filter"></i>
        絞り込み検索
      </h5>
      <%= form_with url: posts_path, method: :get, local: true do |f| %>
        <div class="row g-3 mb-3">
          <div class="col-12">
            <%= f.label :keyword, "施設名・住所", class: "form-label fw-bold" %>
            
            <%= f.text_field :keyword,
              value: params[:keyword],
              class: "form-control",
              placeholder: "○○公園、○○市○○区" %>
          </div>
        </div>

        <div class="row g-3 mb-3">
          <div class="col-md-4">
            <%= f.label :category, "カテゴリ", class: "form-label fw-bold" %>

            <%= f.select :category,
                 Post.categories_i18n.invert,
                  { include_blank: "すべて" },
                  class: "form-select" %>
          </div>

          <div class="col-md-4">
            <%= f.label :parking, "駐車場", class: "form-label fw-bold" %>

            <%= f.select :parking,
                  Post.parkings_i18n.invert,
                  { include_blank: "すべて" },
                  class: "form-select" %>
          </div>

          <div class="col-md-4">
            <%= f.label :fee, "利用料金", class: "form-label fw-bold" %>

            <%= f.select :fee,
                  Post.fees_i18n.invert,
                  { include_blank: "すべて" },
                  class: "form-select" %>
          </div>
        </div>

        <div class="row justify-content-center">
          <div class="col-md-3">
            <%= f.submit "絞り込む",
              class: "btn btn-asobow w-100 rounded-pill fw-bold" %>
          </div>
        
          <div class="col-md-3">
            <%= link_to "条件をリセット",
              posts_path,
              class: "btn btn-light w-100 border rounded-pill" %>
          </div>

        </div>
      <% end %>
    </div>
  </div>

  <% if @posts.any? %>
    <div class="row">
      <%= render partial: "post", collection: @posts %>
    </div>

    <div class="d-flex justify-content-center mt-4">
      <%= paginate @posts %>
    </div>
  <% else %>
    <p class="text-center text-muted py-5">
      <% if params[:category].present? ||
            params[:parking].present? ||
            params[:fee].present? %>
        条件に一致する投稿はありません
      <% else %>
       まだ投稿はありません。
      <% end %>
    </p>
  <% end %>
</div>
<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <% if @post.images.attached? %>
          <div class="d-flex overflow-auto">
            <% @post.images.each do |image| %>
              <%= image_tag image,
                  class: "post-show-image",
                  style: "height: 320px; min-width: 100%; object-fit: contain;" %>
            <% end %>
          </div>
        <% else %>
          <div class="bg-light text-center py-5 text-muted">
            no image
          </div>
        <% end %>

        <div class="card-body p-4">
          <h2 class="fw-bold mb-3">
            <i class="fa-solid fa-location-dot"></i>
            <%= @post.place_name %>
          </h2>

          <p class="text-muted mb-2">
            <%= @post.title %>
          </p>

          <div class="text-warning fw-bold mb-2">
            <div class="raty-read-only" data-score="<%= @post.rating %>"></div>
          </div>

          <p class="text-muted mb-4">
            <%= @post.address %>
          </p>

          <div class="mb-4">
            <p class="mb-0"><%= simple_format(@post.body) %></p>
          </div>

          <div class="row align-items-start mb-3">
            <div class="col-9 col-md-10"> 
              <% if @post.tags.present? %> 
                <div class="d-flex flex-wrap gap-2"> 
                  <% @post.tags.each do |tag| %> 
                    <%= link_to "##{tag.name}", tag_path(tag), class: "tag-badge" %> 
                  <% end %> 
                </div> 
              <% end %>        
            </div> 
          </div>

          <p class="text-muted small mb-4">
            投稿者：
            <%= link_to @post.user.name, user_path(@post.user) %>
          </p>

          <div class="mb-4">
            <% if logged_in? %>
              <% if @post.favorited_by?(current_user) %>
                <%= link_to post_favorite_path(@post), data: { turbo_method: :delete }, class: "btn btn-outline-danger rounded-pill" do %>
                  <i class="fa-solid fa-heart"></i>
                  <%= @post.favorites.count %>
                <% end %>
              <% else %>
                <%= link_to post_favorite_path(@post), data: { turbo_method: :post }, class: "btn btn-outline-secondary rounded-pill" do %>
                  <i class="fa-regular fa-heart"></i>
                  <%= @post.favorites.count %>
                <% end %>
              <% end %>
            <% else %>
              <i class="fa-solid fa-heart"></i>
              <%= @post.favorites.count %>
            <% end %>
          </div>

          <div id="map"
               data-lat="<%= @post.latitude %>"
               data-lng="<%= @post.longitude %>"
               class="rounded-4 mb-4"
               style="height: 350px;">
          </div>

          <div class="mt-4">
            <h5 class="fw-bold">
              コメント <%= @post.comments.count %>件
            </h5>

            <% if logged_in? %>
              <%= form_with model: [@post, @comment], local: true do |f| %>
                <div class="mb-3">
                  <%= f.text_area :body, class: "form-control rounded-4", rows: 3, placeholder: "コメントを書く" %>
                </div>
                <%= f.submit "コメントする", class: "btn btn-asobow rounded-pill" %>
              <% end %>
            <% else %>
              <p class="text-muted">コメントするにはログインしてください。</p>
            <% end %>
          </div>

          <div class="mt-4 mb-4">
            <% @comments.each do |comment| %>
              <div class="border rounded-4 p-3 mb-3">
                <p class="mb-1 fw-bold">
                  <%= comment.user.name %>
                </p>

                <p class="mb-2">
                  <%= simple_format(comment.body) %>
                </p>

                <% if logged_in? && comment.user == current_user %>
                  <%= link_to "削除", post_comment_path(@post, comment), data: { turbo_method: :delete, turbo_confirm: "コメントを削除しますか？" }, class: "btn btn-outline-danger btn-sm rounded-pill" %>
                <% end %>
              </div>
            <% end %>
          </div>

          <div class="d-flex justify-content-between">
            <%= link_to "一覧へ戻る",
                posts_path,
                class: "btn btn-outline-secondary rounded-pill" %>

            <% if @post.user == current_user %>
              <div>
                <%= link_to "編集",
                    edit_post_path(@post),
                    data: { turbo: false },
                    class: "btn btn-asobow rounded-pill me-2" %>

                <%= link_to "削除",
                    post_path(@post),
                    data: {
                      turbo_method: :delete,
                      turbo_confirm: "本当に削除しますか？"
                    },
                    class: "btn btn-outline-danger rounded-pill" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
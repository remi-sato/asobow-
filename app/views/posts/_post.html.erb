<div class="col-md-6 col-lg-4 mb-4">
  <div class="card shadow-sm border-0 rounded-4 h-100">

    <% if post.images.attached? %>
      <%= image_tag post.images.first,
            class: "card-img-top",
            style: "height:220px; object-fit:contain;" %>
    <% else %>
      <div class="bg-light d-flex justify-content-center align-items-center text-muted"
           style="height:220px;">
        No Image
      </div>
    <% end %>

    <div class="card-body d-flex flex-column">

      <h5 class="fw-bold mb-2">
        <i class="fa-solid fa-location-dot text-danger"></i>
        <%= post.place_name %>
      </h5>

      <p class="mb-2">
        <strong><%= post.title %></strong>
      </p>

      <div class="text-warning mb-2">
        <div class="raty-read-only" data-score="<%= post.rating %>"></div>
      </div>

      <p class="text-muted small mb-2">
        <%= post.address %>
      </p>

      <p class="text-muted small mb-3">
        投稿者：
        <%= link_to post.user.name,
              user_path(post.user),
              class: "text-decoration-none" %>
      </p>

      <div class="mt-auto">

        <div class="d-flex justify-content-between align-items-center mb-3">
          <span>
            <i class="fa-solid fa-heart text-danger"></i>
            <%= post.favorites.count %>

            <span class="ms-3">
              <i class="fa-solid fa-comment text-primary"></i>
              <%= post.comments.count %>
            </span>
          </span>
        </div>

        <%= link_to "詳細を見る",
              post_path(post),
              data: { turbo: false },
              class: "btn btn-asobow w-100 rounded-pill" %>

      </div>

    </div>

  </div>
</div>
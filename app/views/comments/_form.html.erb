<div class="mt-4">
  <h5 class="fw-bold">
    コメント <%= post.comments.count %>件
  </h5>

  <% if logged_in? %>
    <% if comment.errors.any? %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% comment.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: [post, comment] do |f| %>
      <div class="mb-3">
        <%= f.text_area :body,
              class: "form-control rounded-4",
              rows: 3,
              placeholder: "コメントを書く" %>
      </div>

      <%= f.submit "コメントする",
            class: "btn btn-asobow w-100 rounded-pill fw-bold" %>
    <% end %>
  <% else %>
    <p class="text-muted">
      コメントするにはログインしてください。
    </p>
  <% end %>
</div>

<div class="container py-5">

  <div class="text-center mb-5">
    <h2 class="fw-bold">管理者ダッシュボード</h2>
  </div>

  <div class="row g-4">

    <div class="col-md-6">
      <div class="card shadow-sm border-0 rounded-4 h-100">
        <div class="card-body text-center">

          <i class="fa-solid fa-users fa-3x mb-3 text-secondary"></i>

          <h4>会員管理</h4>

          <h2 class="fw-bold"><%= @users_count %></h2>

          <p class="text-muted">登録ユーザー数</p>

          <%= link_to "会員一覧へ", admin_users_path, class: "btn btn-asobow rounded-pill fw-bold px-4" %>

        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card shadow-sm border-0 rounded-4 h-100">
        <div class="card-body text-center">

          <i class="fa-solid fa-map-location-dot fa-3x mb-3 text-secondary"></i>

          <h4>投稿管理</h4>

          <h2 class="fw-bold"><%= @posts_count %></h2>

          <p class="text-muted">投稿数</p>

          <%= link_to "投稿一覧へ", admin_posts_path, class: "btn btn-asobow rounded-pill fw-bold px-4" %>

        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card shadow-sm border-0 rounded-4 h-100">
        <div class="card-body text-center">

          <i class="fa-solid fa-people-group fa-3x mb-3 text-secondary"></i>
          <h4>コミュニティ管理</h4>

          <h2 class="fw-bold"><%= @communities_count %></h2>

          <p class="text-muted">コミュニティ数</p>

          <%= link_to "コミュニティ一覧へ", admin_communities_path, class: "btn btn-asobow rounded-pill fw-bold px-4" %>

        </div>
      </div>
    </div>

  </div>

</div>
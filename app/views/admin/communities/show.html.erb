<%= render "shared/page_card",
      title: "コミュニティ詳細",
      width: "col-lg-8",
      body_class: "p-4" do %>

  <%= render "shared/detail_row",
        label: "コミュニティ名",
        value: @community.name %>

  <%= render "shared/detail_row",
        label: "作成者",
        value: @community.user.name %>

  <%= render "shared/detail_row",
      label: "メンバー一覧（#{@community.community_users.approved.count + 1}人）" do %>
    
    <p class="mb-1">
      <%= @community.user.name %>
      <span class="text-muted small">（作成者）</span>
    </p>

    <% approved_members = @community.community_users.approved.includes(:user) %>

    <% if approved_members.present? %>
      <% approved_members.each do |community_user| %>
        <p class="mb-1">
          <%= community_user.user.name %>
        </p>
      <% end %>
    <% else %>
      <span class="text-muted">
        参加メンバーはいません
      </span>
    <% end %>

  <% end %>

  <%= render "shared/detail_row",
        label: "作成日",
        value: @community.created_at.strftime("%Y/%m/%d") %>

  <%= render "shared/detail_row",
        label: "紹介文",
        value: l(@community.created_at, format: :short) %>

  <%= render "shared/detail_row",
        label: "ルール",
        value: @community.rules %>

  <div class="d-grid gap-2 mt-4">
    <%= link_to "コミュニティを削除",
          admin_community_path(@community),
          data: {
            turbo_method: :delete,
            turbo_confirm: "このコミュニティを削除しますか？"
          },
          class: "btn btn-outline-danger w-100 rounded-pill" %>

    <%= link_to "一覧へ戻る",
          admin_communities_path,
          class: "btn btn-outline-secondary w-100 rounded-pill" %>

  </div>

<% end %>
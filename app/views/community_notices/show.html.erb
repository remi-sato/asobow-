<%= render "shared/page_card",
      title: "送信内容" do %>

  <%= render "shared/detail_row",
        label: "タイトル",
        value: @title %>

  <%= render "shared/detail_row",
        label: "本文" do %>
    <%= simple_format(@body) %>
  <% end %>

  <div class="text-center mt-4">
    <%= link_to "詳細に戻る",
          community_path(@community),
          class: "btn btn-outline-secondary rounded-pill px-4" %>
  </div>

<% end %>
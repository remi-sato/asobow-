<div class="container py-4">

  <h2 class="fw-bold mb-4">
    <i class="fa-solid fa-user"></i>
    <%= @user.name %>さんのプロフィール
  </h2>

  <div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-body">

      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0">
          <i class="fa-solid fa-user"></i>
          プロフィール
        </h4>

        <%= link_to "編集", edit_user_path(@user), class: "btn btn-asobow rounded-pill fw-bold" %>
      </div>

      <% if @user.introduction.present? %>
        <%= simple_format(@user.introduction) %>
      <% else %>
        <p class="text-muted mb-0">
          自己紹介はまだありません。
        </p>
      <% end %>

    </div>
  </div>

  <div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0">
          <i class="fa-solid fa-dog"></i>
          愛犬情報
        </h4>

        <%= link_to "登録", new_dog_path,
            class: "btn btn-asobow rounded-pill fw-bold" %>
      </div>

      <% if @dogs.any? %>
        <%= render partial: "dogs/dog", collection: @dogs, locals: { show_actions: true } %>
      <% else %>
        <p class="text-muted mb-0">まだ愛犬情報が登録されていません。</p>
      <% end %>
    </div>
  </div>

  <%= turbo_frame_tag "my_posts" do %>
    <%= render "my_posts", posts: @posts, user: @user %>
  <% end %>

  <%= turbo_frame_tag "favorite_posts" do %>
    <%= render "favorite_posts", favorite_posts: @favorite_posts %>
  <% end %>

</div>
<div class="col-md-6 col-lg-4 mb-4">
  <div class="card shadow-sm border-0 rounded-4 h-100">
    <div class="card-body d-flex flex-column">

      <h5 class="fw-bold">
        <%= community.name %>
      </h5>

      <div class="mb-2">
        <% if community.user == current_user %>
          <span class="community-status-badge community-status-owner">
            <i class="fa-solid fa-crown"></i>
            作成者
          </span>
        <% elsif community.community_users.approved.exists?(user: current_user) %>
          <span class="community-status-badge community-status-member">
            <i class="fa-regular fa-circle-check"></i>
            参加済
          </span>
        <% elsif community.community_users.pending.exists?(user: current_user) %>
          <span class="community-status-badge community-status-pending">
            <i class="fa-regular fa-clock"></i>
            申請中
          </span>
        <% end %>
      </div>

      <p class="text-muted">
        作成者：<%= link_to community.user.name, user_path(community.user), class: "text-decoration-none" %>
      </p>

      <p>
        <%= truncate(community.introduction, length: 80) %>
      </p>

      <p>
        <i class="fa-solid fa-user-group"></i>
        <%= community.community_users.approved.count + 1 %>人
      </p>

      <div class="mt-auto">
        <%= link_to "詳細",
              community_path(community),
             class: "btn btn-light border w-100 rounded-pill" %>
      </div>

    </div>
  </div>
</div>

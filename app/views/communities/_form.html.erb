<%= form_with model: community do |f| %>
  <% if community.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% community.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, "コミュニティ名", class: "form-label fw-bold" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :introduction, "コミュニティ紹介", class: "form-label fw-bold" %>
    <%= f.text_area :introduction, rows: 5, class:"form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :rules, "コミュニティのルール", class: "form-label fw-bold" %>
    <%= f.text_area :rules, rows: 5, class: "form-control" %>
  </div>

  <div class="text-center">
    <%= f.submit community.persisted? ? "変更を保存する" : "コミュニティを作成する", class: "btn btn-asobow w-100 rounded-pill fw-bold" %>
  </div>
<% end %>


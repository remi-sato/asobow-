<%= render "shared/page_card",
      title: "#{@community.name}の詳細",
      width: "col-lg-8" do %>

  <%= render "shared/detail_row",
        label: "作成者",
        value: @community.user.name %>

  <%= render "shared/detail_row",
        label: "コミュニティ紹介",
        value: @community.introduction %>

  <%= render "shared/detail_row",
        label: "ルール",
        value: @community.rules %>

  <%= render "shared/detail_row",
        label: "メンバー数",
        value: "#{@community.community_users.approved.count}人" %>

  <div class="bg-light rounded-4 p-3 mt-4">
    <h5 class="fw-bold mb-3">
      <i class="fa-solid fa-users"></i>
      メンバー
    </h5>

    <div class="d-flex flex-column gap-2">
      <% @community.community_users.approved.includes(:user).each do |community_user| %>
        <div class="d-flex justify-content-between align-items-center bg-white rounded-4 p-3">

          <div>
            <%= link_to "#{community_user.user.name}さん",
                  user_path(community_user.user),
                  class: "text-decoration-none fw-bold" %>

            <% if community_user.user == @community.user %>
              <span class="badge bg-secondary ms-2">
                オーナー
              </span>
            <% end %>
          </div>

          <% if @community.user == current_user &&
                community_user.user != @community.user %>
            <%= link_to "退会させる",
                  remove_community_user_path(community_user),
                  data: {
                    turbo_method: :delete,
                    turbo_confirm: "#{community_user.user.name}さんを退会させますか？"
                  },
                  class: "btn btn-outline-danger btn-sm rounded-pill" %>
          <% end %>

        </div>
      <% end %>
    </div>
  </div>

  <% dogs = @community.participating_dogs.includes(:user) %>

  <% if dogs.any? %>
    <div class="bg-light rounded-4 p-3 mt-4">
      <h5 class="fw-bold mb-3">
        <i class="fa-solid fa-dog"></i>
        参加メンバーの愛犬
      </h5>

      <div class="d-flex flex-column gap-3">
        <% dogs.each do |dog| %>
          <%= link_to user_path(dog.user),
                class: "d-flex align-items-center gap-3 rounded-4 p-3 bg-white text-decoration-none text-dark" do %>

            <% if dog.image.attached? %>
              <%= image_tag dog.image,
                    class: "rounded-circle object-fit-cover flex-shrink-0",
                    style: "width: 80px; height: 80px;" %>
            <% else %>
              <div class="rounded-circle bg-light d-flex align-items-center justify-content-center flex-shrink-0"
                   style="width: 80px; height: 80px;">
                <i class="fa-solid fa-dog fs-3 text-muted"></i>
              </div>
            <% end %>

            <div>
              <p class="fw-bold mb-1"><%= dog.name %></p>

              <p class="mb-1">
                <%= dog.breed %>・<%= dog.size_i18n %>
              </p>

              <p class="text-muted small mb-0">
                飼い主：<%= dog.user.name %>さん
              </p>
            </div>

          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @community.user == current_user %>

    <div class="mt-4">
      <div class="d-flex gap-2 mb-2">
        <%= link_to "参加申請を確認",
              requests_community_path(@community),
              class: "btn btn-light border flex-fill rounded-pill" %>

        <%= link_to "イベントを通知",
              new_community_community_notice_path(@community),
              class: "btn btn-light border flex-fill rounded-pill" %>
      </div>

      <div class="d-flex gap-2 mb-2">
        <%= link_to "編集",
              edit_community_path(@community),
              class: "btn btn-asobow flex-fill rounded-pill fw-bold" %>

        <%= link_to "削除",
              community_path(@community),
              data: {
                turbo_method: :delete,
                turbo_confirm: "このコミュニティを削除しますか？"
              },
              class: "btn btn-outline-danger flex-fill rounded-pill" %>
      </div>

      <%= link_to "一覧へ戻る",
            communities_path,
            class: "btn btn-outline-secondary w-100 rounded-pill" %>
    </div>

  <% else %>

    <% community_user =
         current_user.community_users.find_by(community: @community) %>

    <div class="d-grid gap-2 mt-4">

      <% if community_user.nil? %>

        <%= link_to "参加申請する",
              new_community_community_user_path(@community),
              class: "btn btn-asobow w-100 rounded-pill fw-bold" %>

      <% elsif community_user.pending? %>

        <p class="text-center text-muted mb-0">
          参加申請中です
        </p>

        <%= link_to "申請を取り消す",
              community_community_user_path(@community, community_user),
              data: {
                turbo_method: :delete,
                turbo_confirm: "参加申請を取り消しますか？"
              },
              class: "btn btn-outline-danger w-100 rounded-pill" %>

      <% elsif community_user.approved? %>

        <p class="text-center text-success fw-bold mb-0">
          参加中です
        </p>

        <%= link_to "退会する",
              community_community_user_path(@community, community_user),
              data: {
                turbo_method: :delete,
                turbo_confirm: "このコミュニティから退会しますか？"
              },
              class: "btn btn-outline-danger w-100 rounded-pill" %>

      <% elsif community_user.rejected? %>

        <p class="text-center text-danger mb-0">
          参加申請が拒否されました
        </p>

      <% end %>

      <%= link_to "一覧へ戻る",
            communities_path,
            class: "btn btn-outline-secondary w-100 rounded-pill" %>
    </div>

  <% end %>

<% end %>

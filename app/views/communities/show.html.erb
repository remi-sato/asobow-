<%= render "shared/page_card", title: "#{@community.name}コミュニティの詳細" do %>

  <%= render "shared/page_card",
    title: "#{@community.name}コミュニティの詳細",
    width: "col-lg-8" do %>

  <%= render "shared/detail_row",
    label: "作成者",
    value: @community.user.name %>

  <%= render "shared/detail_row",
    label: "コミュニティ紹介",
    value: @community.introduction %>

  <%= render "shared/detail_row",
    label: "ルール",
    value: @community.rules %>

  <%= render "shared/detail_row",
    label: "メンバー数",
    value: "#{@community.community_users.approved.count + 1}人" %>

  <% if @community.user == current_user %>
    <div class="text-center mt-4">
      <%= link_to "参加申請を確認", requests_community_path(@community), class: "btn btn-outline-warning w-100 rounded-pill mb-2" %>
      <%= link_to "イベントを通知",  new_community_community_notice_path(@community), class: "btn btn-outline-warning w-100 rounded-pill mb-2" %>
      <%= link_to "編集", edit_community_path(@community), class: "btn btn-asobow w-100 rounded-pill mb-2" %>
      <%= link_to "削除", community_path(@community), data: {turbo_method: :delete, turbo_confirm: "このコミュニティを削除しますか？"}, class: "btn btn-outline-danger w-100 rounded-pill mb-2" %>
      <%= link_to "一覧に戻る", communities_path, class: "btn btn-outline-secondary w-100 rounded-pill" %>
    </div>

  <% else %>
    <% community_user = current_user.community_users.find_by(community: @community) %>

    <div class="text-center mt-4">
      <% if community_user.nil? %>
        <%= link_to "参加申請する", community_community_users_path(@community), data: { turbo_method: :post, turbo_confirm: "このコミュニティに参加しますか？"}, class: "btn btn-warning rounded-pill px-4" %>
      <% elsif community_user.pending? %>
        <p class="text-muted">参加申請中です</p>

        <%= link_to "申請を取り消す", community_community_user_path(@community, community_user), data: { turbo_method: :delete, turbo_confirm: "参加申請を取り消しますか？"}, class: "btn btn-outline-danger rounded-pill px-4" %>
      <% elsif community_user.approved? %>
        <p class="text-success fw-bold">参加中です</p>
      <% elsif community_user.rejected? %>
        <p class="text-danger">参加申請が拒否されました</p>
      <% end %>
    </div>
  <% end %>
<% end %>
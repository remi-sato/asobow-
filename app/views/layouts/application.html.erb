<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Asobow" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="google-maps-api-key" content="<%= ENV["Maps_API_Key"] %>">

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <script src="https://kit.fontawesome.com/15835ef7f7.js" crossorigin="anonymous"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="header">

      <div class="header-left">
        <button class="menu-button" id="menuButton">
          <i class="fa-solid fa-bars"></i>
        </button>

        <nav class="hamburger-menu" id="hamburgerMenu">
          <%= link_to root_path do %> 
            <i class="fa-solid fa-house"></i>
            トップ
          <% end %>
          <%= link_to about_path do %> 
            <i class="fa-solid fa-dog"></i>
            このサイトについて
          <% end %>

          <% if logged_in? %>
            <%= link_to new_post_path,data: { turbo: false} do %>
              <i class="fa-solid fa-paw"></i>
              投稿する
            <% end %>
            <%= link_to posts_path do %>
              <i class="fa-solid fa-tree"></i>
              投稿一覧
            <% end %>
            <%= link_to tags_path do %>
              <i class="fa-solid fa-tags"></i>
                タグ一覧
            <% end %>
            <%= link_to communities_path do %>
              <i class="fa-solid fa-people-group"></i>
              コミュニティ一覧
            <% end %>
            <%= link_to mypage_path do %>
              <i class="fa-solid fa-user"></i>
                マイページ
            <% end %>
          <% end %>
        </nav>
      </div>

      <div class="header-center">
        <%= link_to root_path, data: { turbo: false } do %>
          <%= image_tag "ロゴ.png" , class: "logo" %>
        <% end %>
      </div>

      <div class="header-right">
        <% if logged_in? %>
          <%= link_to logout_path, data: { turbo_method: :delete }, class: "btn btn-outline-secondary rounded-pill px-3 me-2" do %>
            ログアウト
          <% end %>
        <% else %>
          <%= link_to "ログイン", login_path, class: "btn btn-outline-secondary rounded-pill px-3 me-2" %>
          <%= link_to "新規登録", new_user_path, class: "btn btn-asobow rounded-pill px-3 me-2" %>
        <% end %>
      </div>

    </header>

    <% if logged_in? %>
      <div class="search-bar container my-3">
        <%= form_with url: search_path, method: :get, local: true do |f| %>

          <%= f.select :range, options_for_select([["ユーザー", "User"], ["投稿", "Post"], ["タグ", "Tag"], ["コミュニティ", "Community"]]), {}, class: "form-select d-inline-block w-auto" %>

          <%= f.select :search, options_for_select([["完全一致", "perfect_match"], ["前方一致", "forward_match"], ["後方一致", "backward_match"], ["部分一致", "partial_match"]]), {}, class: "form-select :search, d-inline-block w-auto" %>

          <%= f.text_field :word, placeholder: "キーワードを入力", class: "form-control d-inline-block w-auto" %>

          <%= f.submit "検索", class: "btn btn-asobow" %>

        <% end %>  
      </div>
    <% end %>

   
    <main>
      <div class="container mt-3">
        <% flash.each do |key, message| %>
          <div class="alert <%= key == "notice" ? "alert-success" : "alert-danger" %>" role="alert">
            <%= message %>
          </div>
        <% end %>

        <%= yield %>
      </div>
    </main>
    
    <footer>
    </footer>
  </body>
</html>

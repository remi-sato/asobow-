<!DOCTYPE html>
<html>
  <head>
    <title>Asobow Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <script src="https://kit.fontawesome.com/15835ef7f7.js" crossorigin="anonymous"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="header">
  <div class="header-left">
    <% if admin_logged_in? %>
      <button class="menu-button" id="menuButton">
        <i class="fa-solid fa-bars"></i>
      </button>

      <nav class="hamburger-menu" id="hamburgerMenu">
        <%= link_to admin_root_path do %>
          <i class="fa-solid fa-house"></i>
          管理トップ
        <% end %>

        <%= link_to admin_users_path do %>
          <i class="fa-solid fa-user"></i>
          会員管理
        <% end %>

        <%= link_to admin_posts_path do %>
          <i class="fa-solid fa-tree"></i>
          投稿管理
        <% end %>

        <%= link_to admin_communities_path do %>
          <i class="fa-solid fa-people-group"></i>
          コミュニティ管理
        <% end %>

        <%= link_to admin_logout_path, data: { turbo_method: :delete } do %>
          <i class="fa-solid fa-right-from-bracket"></i>
          ログアウト
        <% end %>
      </nav>
    <% end %>
  </div>

  <div class="header-center">
    <%= link_to admin_root_path do %>
      <%= image_tag "ロゴ.png", class: "logo" %>
    <% end %>
  </div>

  <div class="header-right"></div>
</header>

    <main>
      <div class="container mt-3">
        <% flash.each do |key, message| %>
          <div class="alert <%= key == "notice" ? "alert-success" : "alert-danger" %>" role="alert">
            <%= message %>
          </div>
        <% end %>

        <%= yield %>
      </div>
    </main>
  </body>
</html>
<!DOCTYPE html>
<html>
  <head>
    <title>Asobow Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <script src="https://kit.fontawesome.com/15835ef7f7.js" crossorigin="anonymous"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="header">
      <div class="header-left"></div>

      <div class="header-center">
        <%= link_to admin_root_path do %>
          <%= image_tag "ロゴ.png", class: "logo" %>
        <% end %>
      </div>

      <div class="header-right">
        <% if admin_logged_in? %>
          <%= link_to "ログアウト", admin_logout_path, data: { turbo_method: :delete }, class: "btn btn-outline-secondary rounded-pill px-3 me-2" %>
          <%= link_to "管理トップ", admin_root_path, class: "btn btn-outline-secondary rounded-pill px-3 me-2" %>
          <%= link_to "会員管理", admin_users_path, class: "btn btn-outline-secondary rounded-pill px-3 me-2" %>
          <%= link_to "投稿管理", admin_posts_path, class: "btn btn-outline-secondary rounded-pill px-3 me-2" %>
        <% end %>
      </div>
    </header>

    <main>
      <div class="container mt-3">
        <% flash.each do |key, message| %>
          <div class="alert <%= key == "notice" ? "alert-success" : "alert-danger" %>" role="alert">
            <%= message %>
          </div>
        <% end %>

        <%= yield %>
      </div>
    </main>
  </body>
</html>